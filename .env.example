# ═════════════════════════════════════════════════════════════════════════════
# ROMVault — variaveis de ambiente. Ha DOIS arquivos .env diferentes:
# ═════════════════════════════════════════════════════════════════════════════

# ── (A) apps/web/.env  →  chaves PUBLICAS (vao pro bundle do navegador) ───────
# Copie estas linhas para apps/web/.env. A anon/publishable e segura no cliente.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
VITE_APP_ENV=development

# ── (B) .env na RAIZ do repo  →  SERVER-ONLY (importador `npm run import`) ─────
# Copie estas linhas para .env na raiz. A SERVICE KEY faz bypass do RLS —
# ⚠️  NUNCA a coloque num VITE_ nem no cliente. So o importador Node a usa.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: so para `npm run import -- --source=igdb`
# App em https://dev.twitch.tv/console/apps (a IGDB usa OAuth da Twitch).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
