{
  "name": "romvault",
  "version": "0.1.0",
  "private": true,
  "description": "ROMVault — hub de romhacking. Catálogo de jogos, romhacks, traduções, documentos e ferramentas.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @romvault/web",
    "build": "npm run build --workspace @romvault/core && npm run build --workspace @romvault/web",
    "lint": "npm run lint --workspace @romvault/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "preview": "npm run preview --workspace @romvault/web",
    "import": "node scripts/import.mjs",
    "import:igdb": "node scripts/import.mjs --source=igdb",
    "db:login": "supabase login",
    "db:link": "supabase link",
    "db:push": "supabase db push",
    "db:new": "supabase migration new",
    "db:diff": "supabase db diff",
    "db:types": "supabase gen types typescript --linked > packages/core/src/database.types.ts"
  },
  "engines": {
    "node": ">=20"
  }
}
